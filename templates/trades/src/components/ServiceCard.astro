---
// ServiceCard.astro — one tile on the /services index, links to /services/<slug>.
const { service } = Astro.props as {
  service: { slug: string; name: string; short_description: string };
};
---
<a
  href={`/services/${service.slug}`}
  class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-md"
>
  <div
    class="flex h-10 w-10 items-center justify-center rounded-lg text-white"
    style="background:var(--brand-primary)"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5L20 7"/></svg>
  </div>
  <h3 class="mt-4 text-lg font-semibold tracking-tight text-slate-900">{service.name}</h3>
  <p class="mt-2 text-sm leading-relaxed text-slate-600">{service.short_description}</p>
  <span class="mt-4 inline-flex items-center text-sm font-semibold" style="color:var(--brand-primary)">
    Learn more
    <span class="ml-1 transition group-hover:translate-x-0.5">→</span>
  </span>
</a>
