---
// ReviewCard.astro — single testimonial card with stars + text + author.
const { review } = Astro.props as {
  review: { text?: string; rating?: number; author?: string };
};
const stars = Math.round(review.rating ?? 5);
---
<figure class="flex h-full flex-col justify-between rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <div class="flex items-center gap-1 text-amber-400" aria-label={`${stars} out of 5 stars`}>
    {Array.from({ length: 5 }).map((_, i) => (
      <svg width="16" height="16" viewBox="0 0 20 20" fill={i < stars ? "currentColor" : "none"} stroke="currentColor" stroke-width="1">
        <path d="M10 1.5l2.6 5.3 5.9.9-4.3 4.2 1 5.9L10 15l-5.3 2.8 1-5.9L1.5 7.7l5.9-.9z"/>
      </svg>
    ))}
  </div>
  <blockquote class="mt-4 text-base leading-relaxed text-slate-700">
    “{review.text ?? "Great service."}”
  </blockquote>
  {review.author && (
    <figcaption class="mt-4 text-sm font-medium text-slate-500">— {review.author}</figcaption>
  )}
</figure>
