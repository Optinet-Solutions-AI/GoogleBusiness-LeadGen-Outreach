---
// Footer.astro — site footer: business identity, hours, quick links, sitemap.
const { data } = Astro.props as { data: any };
const hours: Record<string, string> | null = data.business_hours ?? null;
const dayOrder = ["mon", "tue", "wed", "thu", "fri", "sat", "sun"];
const year = new Date().getFullYear();
---
<footer class="mt-24 border-t border-slate-200 bg-slate-50">
  <div class="mx-auto grid max-w-6xl grid-cols-1 gap-10 px-4 py-12 sm:px-6 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="flex items-center gap-2">
        <span class="inline-block h-7 w-7 rounded-md" style="background:var(--brand-primary)"></span>
        <span class="text-base font-semibold">{data.business_name}</span>
      </div>
      <p class="mt-3 max-w-md text-sm text-slate-600">
        {data.copy?.hero_subhead ?? data.copy?.hero_tagline}
      </p>
      {data.address && (
        <p class="mt-3 text-sm text-slate-600">{data.address}</p>
      )}
      {data.phone && (
        <p class="mt-1 text-sm">
          <a href={`tel:${data.phone}`} class="font-semibold" style="color:var(--brand-primary)">
            {data.phone}
          </a>
        </p>
      )}
    </div>

    {hours && (
      <div>
        <h4 class="text-sm font-semibold text-slate-900">Hours</h4>
        <ul class="mt-3 space-y-1 text-sm text-slate-600">
          {dayOrder.filter((d) => hours[d]).map((d) => (
            <li class="flex justify-between gap-3">
              <span class="capitalize">{d}</span>
              <span>{hours[d]}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <div>
      <h4 class="text-sm font-semibold text-slate-900">Sitemap</h4>
      <ul class="mt-3 space-y-1 text-sm text-slate-600">
        <li><a href="/"             class="hover:text-slate-900">Home</a></li>
        <li><a href="/about"        class="hover:text-slate-900">About</a></li>
        <li><a href="/services"     class="hover:text-slate-900">Services</a></li>
        <li><a href="/service-area" class="hover:text-slate-900">Service Area</a></li>
        <li><a href="/contact"      class="hover:text-slate-900">Contact</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-slate-200 px-4 py-6 text-center text-xs text-slate-500 sm:px-6">
    © {year} {data.business_name}. All rights reserved.
  </div>
</footer>
