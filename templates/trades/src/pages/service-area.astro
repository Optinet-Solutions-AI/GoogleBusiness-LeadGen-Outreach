---
// pages/service-area.astro — /service-area
import data from "../data.json";
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";

const areas = (data.service_areas ?? []) as string[];
---
<BaseLayout
  title="Service Area"
  description={`Cities served by ${data.business_name}`}
  path="/service-area"
>
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 sm:py-20">
    <p class="text-sm font-semibold uppercase tracking-wider" style="color:var(--brand-primary)">
      Service area
    </p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">Where we work</h1>
    <p class="mt-4 text-lg text-slate-700">
      {data.copy?.service_area_intro ?? `${data.business_name} serves the surrounding area.`}
    </p>

    {areas.length > 0 ? (
      <ul class="mt-10 grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4">
        {areas.map((a) => (
          <li class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-center text-sm font-medium text-slate-800 shadow-sm">
            {a}
          </li>
        ))}
      </ul>
    ) : (
      data.address && (
        <p class="mt-6 text-slate-600">Based at <span class="font-medium text-slate-800">{data.address}</span>.</p>
      )
    )}

    <p class="mt-10 text-sm text-slate-500">
      Not sure if we cover your address? Just call — we'll tell you straight.
    </p>
  </section>

  <CTA data={data} headline="Outside the list? Call us anyway." />
</BaseLayout>
