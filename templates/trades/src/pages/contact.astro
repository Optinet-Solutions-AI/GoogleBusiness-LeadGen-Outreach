---
// pages/contact.astro — /contact
import data from "../data.json";
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactForm from "../components/ContactForm.astro";

const hours: Record<string, string> | null = data.business_hours ?? null;
const dayOrder = ["mon", "tue", "wed", "thu", "fri", "sat", "sun"];
---
<BaseLayout
  title="Contact"
  description={`Get in touch with ${data.business_name}`}
  path="/contact"
>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
    <p class="text-sm font-semibold uppercase tracking-wider" style="color:var(--brand-primary)">
      Get in touch
    </p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">
      Talk to {data.business_name}
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-slate-600">
      {data.copy?.contact_blurb ?? "Tell us what's going on — we'll quote it on the call."}
    </p>

    <div class="mt-10 grid grid-cols-1 gap-10 lg:grid-cols-5">
      <div class="lg:col-span-3">
        <ContactForm data={data} />
      </div>

      <aside class="space-y-6 lg:col-span-2">
        {data.phone && (
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Phone</p>
            <a href={`tel:${data.phone}`} class="mt-1 block text-2xl font-bold" style="color:var(--brand-primary)">
              {data.phone}
            </a>
          </div>
        )}

        {data.address && (
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Address</p>
            <p class="mt-1 text-base text-slate-800">{data.address}</p>
            <a
              href={`https://maps.google.com/?q=${encodeURIComponent(data.address)}`}
              target="_blank"
              rel="noopener"
              class="mt-2 inline-block text-sm font-semibold"
              style="color:var(--brand-primary)"
            >Open in Google Maps →</a>
          </div>
        )}

        {hours && (
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Hours</p>
            <ul class="mt-2 space-y-1 text-sm text-slate-700">
              {dayOrder.filter((d) => hours[d]).map((d) => (
                <li class="flex justify-between gap-3">
                  <span class="capitalize">{d}</span>
                  <span>{hours[d]}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </section>
</BaseLayout>
