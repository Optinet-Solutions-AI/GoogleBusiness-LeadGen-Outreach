---
/**
 * Base.astro — Root layout for every page.
 *
 * Inputs:  title, description, lcpImage (page-level overrides)
 * Outputs: Lighthouse-13-tuned head — nested JSON-LD entity graph, OG / Twitter
 *          cards, AI-friendly robots directives, palette CSS variables,
 *          dynamic favicon, optional LCP preload.
 * Used by: every page in src/pages/
 *
 * The schema graph is intentionally nested (LocalBusiness ↔ WebSite ↔ WebPage,
 * with Service / Review / Place children) per the 2026 AEO playbook — flat
 * schema gives no AI-search lift; nested @id-cross-references do.
 */
import "../styles/global.css";
import data from "../lib/data";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StickyBar from "../components/cta/sticky-bar";

interface Props {
  title?: string;
  description?: string;
  /** Above-the-fold hero image URL — emitted as <link rel="preload"> for LCP. */
  lcpImage?: string;
}
const { title, description, lcpImage } = Astro.props;
const pageTitle = title ? `${title} — ${data.business_name}` : data.business_name;
const pageDesc = description ?? data.copy.meta_description;
const p = data.palette;

// astro.config.mjs reads SITE_URL from env at build time. Stage-3 passes
// `https://<slug>.pages.dev` so canonical/og/sitemap URLs are correct per-site.
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const pageUrl = Astro.url.href;
const ogImage = lcpImage ?? data.photos[0] ?? data.logo_url ?? null;

// Convert each palette hex to "R G B" so Tailwind's <alpha-value> modifier
// works (see tailwind.config.cjs). Falls back to neutral on bad input.
function hexToTriplet(hex: string, fallback = "0 0 0"): string {
  const m = hex.replace("#", "").match(/^([0-9a-f]{6})$/i);
  if (!m) return fallback;
  const n = parseInt(m[1], 16);
  return `${(n >> 16) & 0xff} ${(n >> 8) & 0xff} ${n & 0xff}`;
}

const t = {
  primary: hexToTriplet(p.primary, "31 78 121"),
  primary_text: hexToTriplet(p.primary_text, "255 255 255"),
  accent: hexToTriplet(p.accent, "224 123 0"),
  surface: hexToTriplet(p.surface, "255 255 255"),
  surface_alt: hexToTriplet(p.surface_alt, "244 247 250"),
  neutral_900: hexToTriplet(p.neutral_900, "26 31 38"),
  neutral_500: hexToTriplet(p.neutral_500, "107 114 128"),
};

// Inline per-site favicon (initial-on-brand-color). Avoids a separate file
// per build and lets each site carry its own colors without a pre-step.
const initial = (data.business_name[0] ?? "·").replace(/[<>&"']/g, "");
const faviconSvg =
  `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'>` +
  `<rect width='32' height='32' rx='6' fill='${p.primary}'/>` +
  `<text x='16' y='22' font-family='Inter,system-ui,sans-serif' font-size='18' ` +
  `font-weight='700' text-anchor='middle' fill='${p.primary_text}'>${initial}</text>` +
  `</svg>`;
const faviconHref = `data:image/svg+xml;utf8,${encodeURIComponent(faviconSvg)}`;

// ── Theme resolution ───────────────────────────────────────────────────────
// Gemini-picked theme overrides defaults; defaults come from niche when
// no explicit theme is supplied.
const niche = data.niche ?? "home-services";
const theme = data.theme ?? {};
const fontPair = theme.font_pair ??
  (niche === "professional-services" ? "classical-serif"
    : niche === "fitness-pet" ? "modern-sans"
    : niche === "home-services" || niche === "landscaping-construction" ? "modern-sans"
    : "editorial-serif");
const buttonStyle = theme.button_style ?? "solid";
const background = theme.background ?? "plain";

// Each font_pair maps to one Google Fonts URL + the CSS-var values that
// Tailwind reads (--font-heading / --font-body). One stylesheet load total
// so Lighthouse stays happy.
const FONT_DEFS: Record<string, { href: string; heading: string; body: string }> = {
  "editorial-serif": {
    href: "https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=optional",
    heading: '"Fraunces"',
    body: '"Inter"',
  },
  "modern-sans": {
    href: "https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&display=optional",
    heading: '"Space Grotesk"',
    body: '"Inter"',
  },
  "classical-serif": {
    href: "https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Lato:wght@400;700&display=optional",
    heading: '"Cormorant Garamond"',
    body: '"Lato"',
  },
};
const fontDef = FONT_DEFS[fontPair] ?? FONT_DEFS["editorial-serif"];

// ── JSON-LD entity graph ──────────────────────────────────────────────────
const businessId = `${siteUrl}/#business`;
const websiteId = `${siteUrl}/#website`;

const localBusiness: Record<string, unknown> = {
  "@type": "LocalBusiness",
  "@id": businessId,
  name: data.business_name,
  url: siteUrl,
  priceRange: "$$",
  ...(data.phone ? { telephone: data.phone } : {}),
  ...(data.email ? { email: data.email } : {}),
  ...(data.address
    ? { address: { "@type": "PostalAddress", streetAddress: data.address } }
    : {}),
  ...(data.category
    ? {
        description: `${data.category} serving ${
          data.address?.split(",").slice(-2, -1)[0]?.trim() ?? "the local area"
        }.`,
      }
    : {}),
  ...(data.logo_url
    ? { logo: data.logo_url, image: data.logo_url }
    : data.photos[0]
      ? { image: data.photos[0] }
      : {}),
  ...(data.rating && data.review_count
    ? {
        aggregateRating: {
          "@type": "AggregateRating",
          ratingValue: data.rating,
          reviewCount: data.review_count,
          bestRating: 5,
          worstRating: 1,
        },
      }
    : {}),
  ...(data.reviews.length
    ? {
        review: data.reviews
          .filter((r) => r.text && r.text.length > 10)
          .slice(0, 3)
          .map((r) => ({
            "@type": "Review",
            itemReviewed: { "@id": businessId },
            author: { "@type": "Person", name: r.author ?? "Customer" },
            reviewBody: r.text,
            ...(r.rating
              ? {
                  reviewRating: {
                    "@type": "Rating",
                    ratingValue: r.rating,
                    bestRating: 5,
                  },
                }
              : {}),
          })),
      }
    : {}),
  ...(data.service_areas?.length
    ? {
        areaServed: data.service_areas
          .slice(0, 10)
          .map((a) => ({ "@type": "Place", name: a })),
      }
    : {}),
  ...(data.copy.services.length
    ? {
        makesOffer: data.copy.services.map((s) => ({
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: s.name,
            description: s.short_description,
            url: `${siteUrl}/services/${s.slug}`,
            provider: { "@id": businessId },
          },
        })),
      }
    : {}),
};

const website = {
  "@type": "WebSite",
  "@id": websiteId,
  url: siteUrl,
  name: data.business_name,
  publisher: { "@id": businessId },
  inLanguage: "en",
};

const webPage = {
  "@type": "WebPage",
  "@id": pageUrl,
  url: pageUrl,
  name: pageTitle,
  description: pageDesc,
  isPartOf: { "@id": websiteId },
  about: { "@id": businessId },
  inLanguage: "en",
  ...(ogImage ? { primaryImageOfPage: { "@type": "ImageObject", url: ogImage } } : {}),
};

const graph = {
  "@context": "https://schema.org",
  "@graph": [localBusiness, website, webPage],
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={pageUrl} />

    {/* Robots: index + follow + the largest preview Google permits.
        We deliberately do NOT use nosnippet / max-snippet:0 — the goal is
        AEO citation share, so we want LLMs to extract liberally. AI-bot
        allowlist lives in /robots.txt. */}
    <meta
      name="robots"
      content="index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1"
    />

    {/* Open Graph + Twitter card for social previews. */}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content={data.business_name} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <meta name="theme-color" content={p.primary} />
    <link rel="icon" href={faviconHref} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={faviconHref} />

    {/* Preconnect early so font + image origin handshakes overlap with HTML
        parse rather than stacking later in the critical path. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    {/* font-display=optional eliminates CLS from font-swap entirely. The
        loaded font pair is data-driven (data.theme.font_pair) so the Tailwind
        font-heading / font-body utilities resolve to the chosen family via
        --font-heading / --font-body CSS variables set below. */}
    <link rel="stylesheet" href={fontDef.href} />

    {/* Preload the LCP image when the page knows about one. fetchpriority on
        the <img> alone is too late — the request only fires after HTML parse.
        rel=preload kicks it off in the head. */}
    {lcpImage && (
      <link rel="preload" as="image" href={lcpImage} fetchpriority="high" />
    )}

    {/* Palette + font-family CSS variables. Stage-3 writes data.json, those
        values land here. --font-heading / --font-body drive Tailwind's
        font-heading / font-body utilities (see tailwind.config.cjs). */}
    <style is:global set:html={`:root {
      --c-primary: ${t.primary};
      --c-primary-text: ${t.primary_text};
      --c-accent: ${t.accent};
      --c-surface: ${t.surface};
      --c-surface-alt: ${t.surface_alt};
      --c-neutral-900: ${t.neutral_900};
      --c-neutral-500: ${t.neutral_500};
      --font-heading: ${fontDef.heading}, ui-serif, Georgia, serif;
      --font-body: ${fontDef.body}, ui-sans-serif, system-ui, sans-serif;
    }`}></style>

    <script type="application/ld+json" set:html={JSON.stringify(graph)} />
  </head>
  <body
    class="bg-surface text-ink min-h-screen flex flex-col"
    data-niche={niche}
    data-bg={background}
    data-button={buttonStyle}
    data-font={fontPair}
  >
    {/* Optional theme background overlay — sits behind the entire body
        content. Pure CSS / Tailwind, no JS. The default "plain" emits
        nothing so the existing layout is unchanged. */}
    {background === "aurora-blobs" && (
      <div class="fixed inset-0 -z-10 pointer-events-none overflow-hidden">
        <div
          class="absolute -top-1/3 -left-1/4 w-[60vw] h-[60vw] rounded-full opacity-30 blur-3xl"
          style="background: radial-gradient(circle, rgb(var(--c-primary)) 0%, transparent 70%);"
        />
        <div
          class="absolute -top-1/4 -right-1/4 w-[50vw] h-[50vw] rounded-full opacity-25 blur-3xl"
          style="background: radial-gradient(circle, rgb(var(--c-accent)) 0%, transparent 70%);"
        />
      </div>
    )}
    {background === "animated-gradient-mesh" && (
      <div class="fixed inset-0 -z-10 pointer-events-none gradient-mesh-bg" />
    )}
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <StickyBar client:idle data={data} />
  </body>
</html>
