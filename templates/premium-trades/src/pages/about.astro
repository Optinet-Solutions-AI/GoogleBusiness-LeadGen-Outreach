---
import Base from "../layouts/Base.astro";
import data from "../lib/data";
const c = data.copy;
---
<Base title="About" description={c.about_paragraph.slice(0, 155)}>
  <section class="container-tight pt-16 md:pt-24 pb-12">
    <span class="eyebrow">About</span>
    <h1 class="mt-2 text-5xl md:text-7xl font-semibold tracking-tighter-2 leading-tight-2 text-ink max-w-3xl">
      {data.business_name}
    </h1>
    <p class="mt-6 max-w-2xl text-xl text-ink-muted leading-relaxed">{c.about_paragraph}</p>
  </section>

  <section class="container-tight pb-24 grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
    <div>
      <h2 class="text-2xl md:text-3xl font-bold text-ink">Why people call us</h2>
      <ul class="mt-6 space-y-4">
        {c.about_why_us.map((b) => (
          <li class="flex items-start gap-3 p-4 rounded-2xl bg-surface-alt">
            <span class="mt-0.5 grid place-items-center w-7 h-7 rounded-full bg-brand text-brand-text flex-none">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <span class="text-ink leading-relaxed">{b}</span>
          </li>
        ))}
      </ul>
    </div>
    <div class="space-y-4">
      {data.photos.slice(0, 3).map((src, i) => (
        <img
          src={src}
          alt=""
          width={1200}
          height={900}
          loading="lazy"
          decoding="async"
          class={`w-full rounded-3xl shadow-xl shadow-ink/5 ${i % 2 ? "lg:translate-x-8" : ""}`}
        />
      ))}
    </div>
  </section>
</Base>
