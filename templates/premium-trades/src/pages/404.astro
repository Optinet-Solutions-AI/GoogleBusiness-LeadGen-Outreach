---
import Base from "../layouts/Base.astro";
---
<Base title="Page not found">
  <section class="container-tight py-32 text-center">
    <span class="eyebrow">404</span>
    <h1 class="mt-2 text-6xl md:text-8xl font-semibold tracking-tighter-2 leading-tight-2 text-ink">Page not found</h1>
    <p class="mt-6 max-w-md mx-auto text-lg text-ink-muted">
      That page doesn't exist. Head back home or get in touch.
    </p>
    <div class="mt-8 flex justify-center gap-3">
      <a href="/" class="btn-primary text-base">Back home</a>
      <a href="/contact" class="btn-secondary text-base">Contact</a>
    </div>
  </section>
</Base>
