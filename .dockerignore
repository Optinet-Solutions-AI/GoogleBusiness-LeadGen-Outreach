# Keep the Cloud Run Job image minimal — only ship what runBatch + the
# pipeline + services + lib need. Everything else is dead weight.

**/.git
**/node_modules
**/.next
**/.vercel
**/.turbo
**/dist
**/build
**/.cache
**/.tmp

# Next.js-only surface — the Job never serves HTTP, never renders pages.
web/app/**
web/components/**
web/public/**

# Env / secrets — Secret Manager mounts these, never bake into the image.
.env
.env.*
!.env.example
**/credentials.json
**/token.json

# Misc
**/*.log
**/*.zip
**/.DS_Store
**/coverage
docs/**
final_lineup_master.md
stitch_pipeline_operator_dashboard.zip

# Note: templates/ used to be ignored when only the scrape job ran in
# the container. With stage-3 now wired through Cloud Run, the templates
# need to be inside the image — they're explicitly COPYed in the Dockerfile.
# We keep node_modules/.tmp/dist excluded below so we don't ship stale
# build artifacts from the host.
templates/**/node_modules
templates/**/.astro
templates/**/dist
templates/**/.tmp
