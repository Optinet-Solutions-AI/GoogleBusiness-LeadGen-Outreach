# Copy to .env and fill in real values. Never commit .env.

# --- Runtime ---
APP_ENV=development
PORT=8000
LOG_LEVEL=INFO

# --- Supabase (Postgres) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# --- Scraping providers ---
# At least one of these is required. Pick which one a batch uses via batches.scraper.
# Default is google_places (since that's what we have on the pilot).

# Outscraper — pay-per-lead Google Maps scraper (~$3/1k). Best at scale.
OUTSCRAPER_API_KEY=

# Google Places API (New) — official, $200/mo free credit, ~$35/1k Text Search Pro.
# Get a key at: https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_DEFAULT_REGION=us
GOOGLE_PLACES_DEFAULT_LANGUAGE=en

# --- Google Gemini (site copy generation) ---
# Free tier: 1,500 req/day on Flash. Same Google Cloud project as Places.
# Get a key: https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=
GOOGLE_GENAI_MODEL=gemini-2.5-flash

# --- Cloudflare Pages (hosting) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_ROOT_DOMAIN=

# --- Cloud Run Jobs (long-running pipeline runner) ---
# When all five are set, POST /api/batches/:id/run hands off to a Cloud Run
# Job execution instead of running inline (which has a 60s Vercel cap).
# Leave any blank to fall back to the inline path (fine for local dev).
#
# Auth is via Workload Identity Federation — Vercel's per-invocation OIDC
# token is exchanged at GCP STS for a short-lived access token. No JSON keys.
# Run scripts/setup-wif.sh once to provision and get the values below.
GCP_PROJECT_ID=
GCP_REGION=us-central1
CLOUD_RUN_JOB_NAME=lead-batch-runner
# vercel-trigger-sa@<project>.iam.gserviceaccount.com
GCP_SERVICE_ACCOUNT_EMAIL=
# Full resource path:
#   projects/<num>/locations/global/workloadIdentityPools/<pool>/providers/<prov>
GCP_WORKLOAD_IDENTITY_PROVIDER=

# --- Instantly.ai (cold email) ---
INSTANTLY_API_KEY=
INSTANTLY_FROM_EMAIL=

# --- Stripe (billing — later) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
